# Copy this to .env and fill in your values
# cp .env.example .env

# REQUIRED: Generate a strong secret key
# Linux/Mac: python3 -c "import secrets; print(secrets.token_hex(32))"
# Windows PowerShell: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string-before-deploying

# REQUIRED: Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-

# CORS origins - comma separated, NO spaces, NO quotes
CORS_ORIGINS_STR=http://localhost,http://localhost:3000

# Optional port settings
HTTP_PORT=80
HTTPS_PORT=443

# Frontend API URL
VITE_API_URL=/api

# Environment
ENVIRONMENT=production
